---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL;

const urgences = [
  { label: 'Urgences (UE)', number: '112' },
  { label: 'Police', number: '101' },
  { label: 'Pompiers · Ambulance', number: '112' },
  { label: 'Médecin de garde', number: '1733' },
  { label: 'Pharmacie de garde', number: '0903 99 000' },
  { label: 'Centre antipoison', number: '070 245 245' },
];

interface Item { label: string; value: string; href?: string; icon: string }
interface Theme { icon: string; title: string; items: Item[]; cta?: { label: string; href: string } }

const themes: Theme[] = [
  {
    icon: 'ph:bank-bold',
    title: 'Administration',
    items: [
      { label: 'Hôtel de Ville', value: 'Place Charles II, 6000 Charleroi', icon: 'ph:map-pin-bold' },
      { label: 'Horaires d’ouverture', value: 'Lundi – Vendredi, 8h – 16h', icon: 'ph:clock-bold' },
      { label: 'Standard', value: '+32 71 86 11 11', href: 'tel:+3271861111', icon: 'ph:phone-bold' },
      { label: 'Site officiel de la Ville', value: 'charleroi.be', href: 'https://www.charleroi.be', icon: 'ph:globe-bold' },
    ],
    cta: { label: 'Voir toutes les communes', href: `${base}charleroi` },
  },
  {
    icon: 'ph:bus-bold',
    title: 'Transports',
    items: [
      { label: 'Bus & métro léger', value: 'TEC', href: 'https://www.letec.be', icon: 'ph:bus-bold' },
      { label: 'Train', value: 'Charleroi-Central & Charleroi-Ouest', href: 'https://www.belgiantrain.be', icon: 'ph:train-bold' },
      { label: 'Aéroport', value: 'Brussels South (Gosselies)', href: 'https://www.brussels-charleroi-airport.com', icon: 'ph:airplane-tilt-bold' },
      { label: 'Stationnement', value: 'Parkings & zones payantes en ville', icon: 'ph:car-bold' },
    ],
  },
  {
    icon: 'ph:recycle-bold',
    title: 'Déchets & propreté',
    items: [
      { label: 'Intercommunale', value: 'Tibi', href: 'https://www.tibi.be', icon: 'ph:recycle-bold' },
      { label: 'Collecte', value: 'Calendrier par rue et par commune', icon: 'ph:calendar-dots-bold' },
      { label: 'Recyparcs', value: 'Accès avec la carte d’identité', icon: 'ph:identification-card-bold' },
      { label: 'Encombrants', value: 'Enlèvement sur rendez-vous', icon: 'ph:truck-bold' },
    ],
  },
  {
    icon: 'ph:drop-bold',
    title: 'Énergie & eau',
    items: [
      { label: 'Eau', value: 'SWDE', href: 'https://www.swde.be', icon: 'ph:drop-bold' },
      { label: 'Électricité & gaz', value: 'ORES', href: 'https://www.ores.be', icon: 'ph:lightning-bold' },
      { label: 'Panne d’électricité', value: '078 78 78 00', href: 'tel:078787800', icon: 'ph:warning-bold' },
      { label: 'Odeur de gaz', value: '0800 87 087', href: 'tel:080087087', icon: 'ph:flame-bold' },
    ],
  },
];
---

<Base title="Infos pratiques — Charleroi Métropole · charleroi.info" description="Urgences, administration, transports, déchets et énergie : tous les numéros et services utiles de Charleroi Métropole.">
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="text-ink">Infos pratiques</span>
      </div>
    </nav>

    <div class="border-b border-border bg-surface">
      <div class="u-container py-10">
        <span class="section-mark"></span>
        <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">Infos pratiques</h1>
        <p class="mt-2 max-w-[56ch] text-ink-soft">
          Les numéros et services utiles de Charleroi Métropole : urgences, administration,
          transports, déchets et énergie.
        </p>
      </div>
    </div>

    <!-- Urgences (bandeau sombre) -->
    <section class="u-container pt-10">
      <div class="overflow-hidden rounded-[16px] bg-[#0f1729] text-white">
        <div class="flex items-center gap-3 border-b border-white/10 px-6 py-5">
          <span class="grid size-10 place-items-center rounded-[10px] bg-white/10">
            <Icon name="ph:phone-call-bold" class="size-5" />
          </span>
          <div>
            <h2 class="text-lg font-extrabold tracking-tight">Numéros d’urgence</h2>
            <p class="text-sm text-white/60">Appuyez pour appeler directement</p>
          </div>
        </div>
        <div class="grid grid-cols-2 divide-x divide-y divide-white/10 sm:grid-cols-3 lg:grid-cols-6 lg:divide-y-0">
          {urgences.map((u) => (
            <a href={`tel:${u.number.replace(/\s/g, '')}`} class="group px-5 py-5 text-center transition-colors hover:bg-white/5">
              <p class="font-mono text-xl font-extrabold text-white transition-colors group-hover:text-[#8fb4ff]">{u.number}</p>
              <p class="mt-1 text-xs text-white/60">{u.label}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Thèmes -->
    <section class="u-container pt-10">
      <div class="grid gap-5 md:grid-cols-2">
        {themes.map((t) => (
          <div class="flex flex-col rounded-[12px] border border-border bg-surface p-6">
            <div class="flex items-center gap-3">
              <span class="grid size-11 place-items-center rounded-[10px] bg-accent-tint text-accent">
                <Icon name={t.icon} class="size-6" />
              </span>
              <h2 class="text-lg font-extrabold tracking-tight">{t.title}</h2>
            </div>

            <ul class="mt-4 flex-1">
              {t.items.map((it) => {
                const external = it.href?.startsWith('http');
                const inner = (
                  <>
                    <span class="grid size-9 shrink-0 place-items-center rounded-[8px] bg-surface-muted text-ink-faint transition-colors group-hover:bg-accent-tint group-hover:text-accent">
                      <Icon name={it.icon} class="size-[1.1rem]" />
                    </span>
                    <span class="min-w-0 flex-1">
                      <span class="block text-xs text-ink-faint">{it.label}</span>
                      <span class="block truncate font-semibold text-ink">{it.value}</span>
                    </span>
                    {it.href && (
                      <Icon name={external ? 'ph:arrow-up-right-bold' : 'ph:caret-right-bold'} class="size-4 shrink-0 text-ink-faint transition-colors group-hover:text-accent" />
                    )}
                  </>
                );
                return (
                  <li>
                    {it.href ? (
                      <a href={it.href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined} class="group -mx-2 flex items-center gap-3 rounded-[8px] px-2 py-2.5 transition-colors hover:bg-surface-muted">
                        {inner}
                      </a>
                    ) : (
                      <div class="group flex items-center gap-3 px-2 py-2.5">
                        {inner}
                      </div>
                    )}
                  </li>
                );
              })}
            </ul>

            {t.cta && (
              <a href={t.cta.href} class="mt-3 inline-flex items-center gap-1.5 border-t border-border pt-4 text-sm font-semibold text-accent transition-colors hover:text-accent-hover">
                {t.cta.label}
                <Icon name="ph:arrow-right-bold" class="size-4" />
              </a>
            )}
          </div>
        ))}
      </div>

      <p class="mt-8 flex items-start gap-2 rounded-[10px] border border-border bg-surface p-4 text-sm text-ink-soft">
        <Icon name="ph:info-bold" class="mt-0.5 size-4 shrink-0 text-ink-faint" />
        <span>Informations données à titre indicatif. En cas d’urgence vitale, composez toujours le <strong class="text-ink">112</strong>.</span>
      </p>
    </section>
  </main>

  <Footer />
</Base>
