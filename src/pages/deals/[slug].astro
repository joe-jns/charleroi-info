---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DealCard from '../../components/DealCard.astro';
import { Icon } from 'astro-icon/components';
import { deals, type Deal } from '../../data/deals';

export function getStaticPaths() {
  return deals.map((dl) => ({ params: { slug: dl.slug }, props: { deal: dl } }));
}

const { deal: dl } = Astro.props as { deal: Deal };
const base = import.meta.env.BASE_URL;
const similar = deals.filter((x) => x.category === dl.category && x.slug !== dl.slug).slice(0, 3);
const businessUrl = dl.businessSlug ? `${base}business/${dl.businessSlug}` : null;
---

<Base title={`${dl.title} — ${dl.business} · charleroi.info`} description={dl.description.slice(0, 150)}>
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <a href={`${base}deals`} class="transition-colors hover:text-accent">Bons plans</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="truncate text-ink">{dl.title}</span>
      </div>
    </nav>

    <div class="u-container pt-6">
      <div class="relative overflow-hidden rounded-[14px] border border-border">
        {/* TODO: vraie photo de l'offre */}
        <img src={`https://picsum.photos/seed/${dl.imageSeed}/1600/600`} alt={dl.title} class="h-52 w-full object-cover sm:h-64 lg:h-72" loading="eager" />
        <span class="absolute left-4 top-4 inline-flex items-center rounded-[10px] bg-accent px-3.5 py-2 text-lg font-extrabold text-accent-ink shadow-[0_4px_14px_rgba(14,79,192,0.4)]">
          {dl.discount}
        </span>
      </div>
    </div>

    <div class="u-container mt-6">
      <p class="text-sm font-medium text-ink-faint">{dl.category} · {dl.commune}</p>
      <h1 class="mt-1 text-2xl font-extrabold tracking-tight sm:text-4xl">{dl.title}</h1>
      <p class="mt-2 text-ink-soft">
        Chez {businessUrl ? <a href={businessUrl} class="font-semibold text-accent hover:underline">{dl.business}</a> : <span class="font-semibold text-ink">{dl.business}</span>}
      </p>
    </div>

    <div class="u-container mt-10 grid gap-10 lg:grid-cols-3">
      <div class="space-y-10 lg:col-span-2">
        <section>
          <h2 class="text-xl font-extrabold tracking-tight">L’offre</h2>
          <p class="mt-3 max-w-[68ch] leading-relaxed text-ink-soft">{dl.description}</p>
        </section>

        <section>
          <h2 class="text-xl font-extrabold tracking-tight">Conditions</h2>
          <ul class="mt-4 space-y-2.5">
            {dl.conditions.map((c) => (
              <li class="flex items-start gap-2.5 text-ink-soft">
                <Icon name="ph:info-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
                {c}
              </li>
            ))}
          </ul>
        </section>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-[12px] border border-border bg-surface p-5">
          <div class="mb-4 flex items-center gap-3 rounded-[10px] bg-accent-tint p-4">
            <span class="text-3xl font-extrabold text-accent">{dl.discount}</span>
            <span class="text-sm font-semibold text-ink-soft">{dl.title}</span>
          </div>
          <dl class="space-y-3.5 text-sm">
            <div class="flex items-center gap-3">
              <Icon name="ph:storefront-bold" class="size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Commerce</dt><dd class="font-medium text-ink">{businessUrl ? <a href={businessUrl} class="text-accent hover:underline">{dl.business}</a> : dl.business}</dd></div>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="ph:map-pin-bold" class="size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Commune</dt><dd class="font-medium text-ink">{dl.commune}</dd></div>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="ph:clock-bold" class="size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Valable</dt><dd class="font-medium text-ink">Jusqu’au {dl.validUntil}</dd></div>
            </div>
          </dl>
          {businessUrl && (
            <a href={businessUrl} class="btn btn-primary mt-5 w-full">
              <Icon name="ph:storefront-bold" class="size-4" />
              Voir le commerce
            </a>
          )}
        </div>
      </aside>
    </div>

    {similar.length > 0 && (
      <div class="u-container mt-16 border-t border-border pt-14 lg:mt-20 lg:pt-16">
        <span class="section-mark"></span>
        <h2 class="text-xl font-extrabold tracking-tight">Autres bons plans</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {similar.map((s) => <DealCard deal={s} />)}
        </div>
      </div>
    )}
  </main>

  <Footer />
</Base>
