---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { Icon } from 'astro-icon/components';
import { articles, type Article } from '../../data/articles';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article: a } = Astro.props as { article: Article };
const base = import.meta.env.BASE_URL;
const related = articles.filter((x) => x.slug !== a.slug).slice(0, 3);
---

<Base title={`${a.title} · charleroi.info`} description={a.excerpt}>
  <Header />

  <main id="contenu" class="bg-surface pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <a href={`${base}actualites`} class="transition-colors hover:text-accent">Actualités</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="truncate text-ink">{a.title}</span>
      </div>
    </nav>

    <article class="u-container pt-10">
      <!-- En-tête -->
      <div class="mx-auto max-w-[720px]">
        <a href={`${base}actualites`} class="inline-flex rounded-full bg-accent-tint px-3 py-1 text-xs font-semibold text-accent transition-colors hover:bg-accent-tint-2">{a.category}</a>
        <h1 class="mt-4 text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl">{a.title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-2 text-sm text-ink-faint">
          <span class="font-medium text-ink-soft">{a.author}</span>
          <span>·</span>
          <span>{a.date}</span>
          <span>·</span>
          <span class="inline-flex items-center gap-1"><Icon name="ph:clock-bold" class="size-3.5" />{a.readingTime} de lecture</span>
        </div>
      </div>

      <!-- Visuel -->
      <div class="mx-auto mt-8 max-w-[960px] overflow-hidden rounded-[14px] border border-border">
        {/* TODO: vraie photo de l'article */}
        <img src={`https://picsum.photos/seed/${a.imageSeed}/1600/800`} alt={a.title} class="aspect-[2/1] w-full object-cover" loading="eager" />
      </div>

      <!-- Chapô -->
      <div class="mx-auto mt-10 max-w-[720px]">
        <p class="text-lg font-medium leading-relaxed text-ink">{a.excerpt}</p>
        <div class="mt-6 space-y-5 leading-relaxed text-ink-soft">
          {a.content.map((p) => <p>{p}</p>)}
        </div>

        <!-- Partage -->
        <div class="mt-10 flex items-center gap-3 border-t border-border pt-6">
          <span class="text-sm font-semibold text-ink">Partager&nbsp;:</span>
          <a href="#" aria-label="Partager sur Facebook" class="grid size-9 place-items-center rounded-[8px] border border-border text-ink-soft transition-colors hover:border-accent-tint-2 hover:bg-accent-tint hover:text-accent"><Icon name="ph:facebook-logo-bold" class="size-[1.05rem]" /></a>
          <a href="#" aria-label="Partager sur X" class="grid size-9 place-items-center rounded-[8px] border border-border text-ink-soft transition-colors hover:border-accent-tint-2 hover:bg-accent-tint hover:text-accent"><Icon name="ph:x-logo-bold" class="size-[1.05rem]" /></a>
          <a href="#" aria-label="Partager par e-mail" class="grid size-9 place-items-center rounded-[8px] border border-border text-ink-soft transition-colors hover:border-accent-tint-2 hover:bg-accent-tint hover:text-accent"><Icon name="ph:envelope-simple-bold" class="size-[1.05rem]" /></a>
        </div>
      </div>
    </article>

    {related.length > 0 && (
      <div class="u-container mt-16 border-t border-border pt-14">
        <span class="section-mark"></span>
        <h2 class="text-xl font-extrabold tracking-tight">À lire aussi</h2>
        <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((r) => <ArticleCard article={r} />)}
        </div>
      </div>
    )}
  </main>

  <Footer />
</Base>
