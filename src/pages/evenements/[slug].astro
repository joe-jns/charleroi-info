---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import { Icon } from 'astro-icon/components';
import { upcomingEvents, type Event } from '../../data/events';

export function getStaticPaths() {
  return upcomingEvents.map((e) => ({ params: { slug: e.slug }, props: { event: e } }));
}

const { event: e } = Astro.props as { event: Event };
const base = import.meta.env.BASE_URL;
const similar = upcomingEvents.filter((x) => x.category === e.category && x.slug !== e.slug).slice(0, 3);
const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(e.address)}`;
---

<Base title={`${e.title} · charleroi.info`} description={e.description.slice(0, 150)}>
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <a href={`${base}evenements`} class="transition-colors hover:text-accent">Événements</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="truncate text-ink">{e.title}</span>
      </div>
    </nav>

    <div class="u-container pt-6">
      <div class="relative overflow-hidden rounded-[14px] border border-border">
        {/* TODO: vraie photo de l'événement */}
        <img src={`https://picsum.photos/seed/${e.imageSeed}/1600/600`} alt={e.title} class="h-52 w-full object-cover sm:h-64 lg:h-72" loading="eager" />
        <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-accent px-3 py-1.5 text-sm font-semibold text-accent-ink shadow-sm">
          {e.category}
        </span>
      </div>
    </div>

    <div class="u-container mt-6">
      <p class="text-sm font-medium text-ink-faint">{e.fullDate} · {e.time}</p>
      <h1 class="mt-1 text-2xl font-extrabold tracking-tight sm:text-4xl">{e.title}</h1>
      <p class="mt-2 flex items-center gap-1.5 text-ink-soft">
        <Icon name="ph:map-pin-bold" class="size-4 text-ink-faint" />
        {e.venue} · {e.commune}
      </p>
    </div>

    <div class="u-container mt-10 grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <h2 class="text-xl font-extrabold tracking-tight">À propos de l’événement</h2>
        <p class="mt-3 max-w-[68ch] leading-relaxed text-ink-soft">{e.description}</p>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-[12px] border border-border bg-surface p-5">
          <h2 class="text-sm font-bold uppercase tracking-wider text-ink-faint">Infos pratiques</h2>
          <dl class="mt-4 space-y-3.5 text-sm">
            <div class="flex items-start gap-3">
              <Icon name="ph:calendar-dots-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Date</dt><dd class="font-medium text-ink">{e.fullDate}</dd></div>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="ph:clock-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Heure</dt><dd class="font-medium text-ink">{e.time}</dd></div>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="ph:map-pin-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Lieu</dt><dd class="font-medium text-ink">{e.venue}<br />{e.address}</dd></div>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="ph:ticket-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
              <div><dt class="text-ink-faint">Tarif</dt><dd class="font-medium text-ink">{e.price}</dd></div>
            </div>
            {e.businessSlug && (
              <div class="flex items-start gap-3">
                <Icon name="ph:buildings-bold" class="mt-0.5 size-5 shrink-0 text-accent" />
                <div><dt class="text-ink-faint">Organisé par</dt><dd><a href={`${base}business/${e.businessSlug}`} class="font-medium text-accent hover:underline">{e.venue}</a></dd></div>
              </div>
            )}
          </dl>
          <a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary mt-5 w-full">
            <Icon name="ph:navigation-arrow-bold" class="size-4" />
            S’y rendre
          </a>
        </div>
      </aside>
    </div>

    {similar.length > 0 && (
      <div class="u-container mt-16 border-t border-border pt-14 lg:mt-20 lg:pt-16">
        <span class="section-mark"></span>
        <h2 class="text-xl font-extrabold tracking-tight">Autres événements « {e.category} »</h2>
        <div class="mt-6 grid grid-cols-1 gap-3 lg:grid-cols-2">
          {similar.map((s) => <EventCard event={s} />)}
        </div>
      </div>
    )}
  </main>

  <Footer />
</Base>
