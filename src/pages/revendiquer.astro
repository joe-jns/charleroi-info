---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SelectField from '../components/SelectField.astro';
import { Icon } from 'astro-icon/components';
import { businesses } from '../data/businesses';

const base = import.meta.env.BASE_URL;
const inputCls =
  'w-full rounded-[8px] border border-border-strong bg-surface px-3.5 py-2.5 text-[0.95rem] text-ink outline-none transition-colors placeholder:text-ink-faint focus:border-accent';
const bizData = businesses.map((b) => ({ slug: b.slug, name: b.name, category: b.category, commune: b.commune }));

const roleOptions = [
  { value: 'proprietaire', label: 'Propriétaire' },
  { value: 'gerant', label: 'Gérant(e)' },
  { value: 'employe', label: 'Employé(e) mandaté(e)' },
  { value: 'autre', label: 'Autre' },
];

const perks = [
  'Modifier vos informations et horaires',
  'Ajouter des photos',
  'Répondre aux avis clients',
  'Publier vos offres d’emploi et événements',
];
---

<Base title="Revendiquer une fiche · charleroi.info" description="Vous gérez cet établissement ? Revendiquez sa fiche pour gérer vos informations, avis et publications.">
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="text-ink">Revendiquer une fiche</span>
      </div>
    </nav>

    <div class="border-b border-border bg-surface">
      <div class="u-container py-10">
        <span class="section-mark"></span>
        <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">Revendiquer une fiche</h1>
        <p class="mt-2 max-w-[54ch] text-ink-soft">
          Vous gérez cet établissement ? Revendiquez sa fiche gratuitement pour en prendre le
          contrôle. Nous vérifions chaque demande avant validation.
        </p>
      </div>
    </div>

    <div class="u-container pt-8 lg:grid lg:grid-cols-[1fr_300px] lg:gap-8">
      <div>
        <!-- Fiche ciblée -->
        <div class="mb-6 rounded-[12px] border border-accent-tint-2 bg-accent-tint p-5" data-claim-found hidden>
          <p class="text-xs font-bold uppercase tracking-wider text-accent">Fiche à revendiquer</p>
          <div class="mt-2 flex items-center justify-between gap-4">
            <div>
              <p class="text-lg font-extrabold tracking-tight text-ink" data-claim-name></p>
              <p class="text-sm text-ink-soft" data-claim-meta></p>
            </div>
            <a href="#" class="shrink-0 text-sm font-semibold text-accent hover:underline" data-claim-link>Voir la fiche</a>
          </div>
        </div>

        <div class="mb-6 flex items-start gap-3 rounded-[12px] border border-dashed border-border bg-surface p-5" data-claim-none>
          <Icon name="ph:info-bold" class="mt-0.5 size-5 shrink-0 text-ink-faint" />
          <p class="text-sm text-ink-soft">
            Aucune fiche présélectionnée. Indiquez le nom de l’établissement ci-dessous, ou
            <a href={`${base}annuaire`} class="font-semibold text-accent hover:underline">parcourez l’annuaire</a> pour choisir une fiche.
          </p>
        </div>

        <form data-claim-form class="space-y-8 rounded-[12px] border border-border bg-surface p-6 sm:p-8">
          <input type="hidden" name="businessSlug" data-claim-slug value="" />

          <fieldset class="space-y-4">
            <legend class="text-lg font-extrabold tracking-tight">L’établissement</legend>
            <div>
              <label for="biz" class="mb-1.5 block text-sm font-semibold text-ink">Nom de l’établissement <span class="text-accent">*</span></label>
              <input id="biz" name="business" type="text" required placeholder="Nom de l’établissement" class={inputCls} data-claim-input />
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-semibold text-ink">Votre lien avec l’établissement <span class="text-accent">*</span></label>
              <SelectField name="role" options={roleOptions} placeholder="Choisir…" />
              <p class="mt-1.5 hidden text-xs font-medium text-red-600" data-err="role">Veuillez préciser votre lien.</p>
            </div>
          </fieldset>

          <fieldset class="space-y-4 border-t border-border pt-8">
            <legend class="text-lg font-extrabold tracking-tight">Vos coordonnées</legend>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="cname" class="mb-1.5 block text-sm font-semibold text-ink">Nom complet <span class="text-accent">*</span></label>
                <input id="cname" name="contactName" type="text" required placeholder="Prénom et nom" class={inputCls} />
              </div>
              <div>
                <label for="cemail" class="mb-1.5 block text-sm font-semibold text-ink">E-mail <span class="text-accent">*</span></label>
                <input id="cemail" name="contactEmail" type="email" required placeholder="vous@exemple.be" class={inputCls} />
              </div>
            </div>
            <div>
              <label for="phone" class="mb-1.5 block text-sm font-semibold text-ink">Téléphone</label>
              <input id="phone" name="phone" type="tel" placeholder="+32 71 00 00 00" class={inputCls} />
            </div>
            <div>
              <label for="msg" class="mb-1.5 block text-sm font-semibold text-ink">Comment pouvons-nous vérifier votre lien ?</label>
              <textarea id="msg" name="message" rows="3" placeholder="Ex. e-mail professionnel, numéro d’entreprise, site officiel…" class={inputCls}></textarea>
            </div>
            <label class="flex items-start gap-2.5 text-sm text-ink-soft">
              <input type="checkbox" required class="mt-0.5 size-4 accent-[#0e4fc0]" data-consent />
              J’atteste être autorisé(e) à gérer cet établissement.
            </label>
          </fieldset>

          <div class="border-t border-border pt-6">
            <button type="submit" class="btn btn-primary w-full sm:w-auto">
              <Icon name="ph:seal-check-bold" class="size-4" />
              Envoyer ma demande
            </button>
            <p class="mt-3 text-xs text-ink-faint">Nous revenons vers vous par e-mail après vérification.</p>
          </div>
        </form>

        <div class="hidden rounded-[12px] border border-border bg-surface p-10 text-center" data-success>
          <span class="mx-auto grid size-14 place-items-center rounded-full bg-accent-tint text-accent">
            <Icon name="ph:check-bold" class="size-7" />
          </span>
          <h2 class="mt-5 text-xl font-extrabold tracking-tight">Demande envoyée&nbsp;!</h2>
          <p class="mx-auto mt-2 max-w-[46ch] text-ink-soft">
            Merci. Nous vérifions votre lien avec l’établissement et revenons vers vous par e-mail
            pour valider la revendication.
          </p>
          <a href={base} class="btn btn-ghost mt-6">Retour à l’accueil</a>
        </div>
      </div>

      <aside class="mt-8 lg:mt-0">
        <div class="rounded-[12px] border border-border bg-surface p-5">
          <h2 class="text-sm font-bold uppercase tracking-wider text-ink-faint">Une fois validée</h2>
          <ul class="mt-4 space-y-3">
            {perks.map((p) => (
              <li class="flex items-start gap-2.5 text-sm text-ink-soft">
                <Icon name="ph:check-circle-fill" class="mt-0.5 size-5 shrink-0 text-accent" />
                {p}
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </main>

  <Footer />

  <script type="application/json" id="biz-data" set:html={JSON.stringify(bizData)}></script>
</Base>

<script>
  const base = import.meta.env.BASE_URL;
  const dataEl = document.getElementById('biz-data');
  const form = document.querySelector<HTMLFormElement>('[data-claim-form]');

  if (dataEl && form) {
    type B = { slug: string; name: string; category: string; commune: string };
    const list: B[] = JSON.parse(dataEl.textContent || '[]');
    const slug = new URLSearchParams(location.search).get('fiche');
    const match = slug ? list.find((b) => b.slug === slug) : undefined;

    const found = document.querySelector<HTMLElement>('[data-claim-found]');
    const none = document.querySelector<HTMLElement>('[data-claim-none]');
    if (match) {
      document.querySelector<HTMLElement>('[data-claim-name]')!.textContent = match.name;
      document.querySelector<HTMLElement>('[data-claim-meta]')!.textContent = `${match.category} · ${match.commune}`;
      document.querySelector<HTMLAnchorElement>('[data-claim-link]')!.href = `${base}business/${match.slug}`;
      document.querySelector<HTMLInputElement>('[data-claim-input]')!.value = match.name;
      document.querySelector<HTMLInputElement>('[data-claim-slug]')!.value = match.slug;
      found?.removeAttribute('hidden');
      none?.setAttribute('hidden', '');
    }

    const success = document.querySelector<HTMLElement>('[data-success]');
    const roleInput = form.querySelector<HTMLInputElement>('[name="role"]')!;
    const roleErr = form.querySelector<HTMLElement>('[data-err="role"]');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      if (!roleInput.value) { roleErr?.classList.remove('hidden'); return; }
      roleErr?.classList.add('hidden');
      // TODO(DB): envoyer la demande de revendication à l'API (avec businessSlug).
      form.classList.add('hidden');
      success?.classList.remove('hidden');
      success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
