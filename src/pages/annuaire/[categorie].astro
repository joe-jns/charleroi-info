---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BusinessCard from '../../components/BusinessCard.astro';
import SortSelect from '../../components/SortSelect.astro';
import CommuneSelect from '../../components/CommuneSelect.astro';
import { Icon } from 'astro-icon/components';
import { categories } from '../../data/categories';
import { businesses } from '../../data/businesses';

export function getStaticPaths() {
  return categories.map((c) => ({
    params: { categorie: c.slug },
    props: { category: c, list: businesses.filter((b) => b.categorySlug === c.slug) },
  }));
}

const { category, list } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={`${category.name} à Charleroi Métropole · charleroi.info`} description={`Trouvez les meilleurs établissements de la catégorie ${category.name} à Charleroi et dans toutes les communes.`}>
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <!-- Barre de recherche (haut de page) -->
    <div class="border-b border-border bg-surface">
      <div class="u-container py-5">
        <nav aria-label="Fil d’Ariane" class="mb-4 flex items-center gap-1.5 text-sm text-ink-faint">
          <a href={base} class="transition-colors hover:text-accent">Accueil</a>
          <Icon name="ph:caret-right-bold" class="size-3" />
          <a href={`${base}annuaire`} class="transition-colors hover:text-accent">Annuaire</a>
          <Icon name="ph:caret-right-bold" class="size-3" />
          <span class="text-ink">{category.name}</span>
        </nav>

        <div class="mb-4 flex items-center gap-3">
          <span class="grid size-11 place-items-center rounded-[10px] bg-accent-tint text-accent">
            <Icon name={`ph:${category.icon}`} class="size-6" />
          </span>
          <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">{category.name}</h1>
        </div>

        <form
          data-search-bar
          class="rounded-[12px] border border-border-strong bg-surface p-2 shadow-[0_1px_2px_rgba(15,23,41,0.04)] sm:flex sm:items-stretch sm:gap-2"
        >
          <div class="flex flex-1 items-center gap-2.5 px-3 py-2.5">
            <Icon name="ph:magnifying-glass-bold" class="size-5 shrink-0 text-ink-faint" />
            <label for="q" class="sr-only">Filtrer dans {category.name}</label>
            <input id="q" name="q" type="search" autocomplete="off" placeholder={`Rechercher dans ${category.name}…`} class="w-full bg-transparent text-[1rem] text-ink outline-none placeholder:text-ink-faint" data-q />
          </div>
          <div class="my-1 hidden w-px bg-border sm:block"></div>
          <CommuneSelect />
          <button type="submit" class="btn btn-primary mt-2 w-full sm:mt-0 sm:w-auto">
            <Icon name="ph:magnifying-glass-bold" class="size-4" />
            Rechercher
          </button>
        </form>
      </div>
    </div>

    <div class="u-container pt-8">
      {list.length === 0 ? (
        <div class="rounded-[12px] border border-dashed border-border bg-surface p-12 text-center">
          <Icon name="ph:storefront-bold" class="mx-auto size-9 text-ink-faint" />
          <p class="mt-4 text-lg font-bold text-ink">Aucun établissement pour le moment</p>
          <p class="mt-1 text-ink-soft">Cette catégorie n’a pas encore de fiche. Vous gérez un tel établissement ?</p>
          <a href={`${base}ajouter`} class="btn btn-primary mt-5">
            <Icon name="ph:plus-bold" class="size-4" />
            Ajouter mon entreprise
          </a>
        </div>
      ) : (
        <div class="lg:grid lg:grid-cols-[270px_1fr] lg:gap-8">
          <!-- Bouton filtres (mobile) -->
          <button type="button" class="mb-4 inline-flex items-center gap-2 rounded-[8px] border border-border-strong bg-surface px-4 py-2.5 text-sm font-semibold text-ink lg:hidden" data-filters-toggle aria-expanded="false">
            <Icon name="ph:sliders-horizontal-bold" class="size-4" />
            Filtres
          </button>

          <!-- Sidebar facettes -->
          <aside class="hidden lg:block" data-filters-panel>
            <div class="space-y-6 rounded-[12px] border border-border bg-surface p-5" data-filters>
              <div class="flex items-center justify-between">
                <h2 class="font-extrabold tracking-tight">Filtres</h2>
                <button type="button" class="text-sm font-semibold text-accent transition-colors hover:text-accent-hover" data-reset>Réinitialiser</button>
              </div>

              <div>
                <h3 class="mb-3 text-sm font-bold text-ink">Disponibilité</h3>
                <label class="flex cursor-pointer items-center gap-2.5 py-1 text-sm text-ink-soft transition-colors hover:text-ink">
                  <input type="checkbox" class="size-4 accent-[#0e4fc0]" data-open />
                  Ouvert maintenant
                </label>
              </div>

              <div class="border-t border-border pt-5">
                <h3 class="mb-3 text-sm font-bold text-ink">Note minimum</h3>
                {[
                  { v: '0', l: 'Toutes les notes' },
                  { v: '4.5', l: '4,5 et plus' },
                  { v: '4', l: '4 et plus' },
                  { v: '3.5', l: '3,5 et plus' },
                ].map((o) => (
                  <label class="flex cursor-pointer items-center gap-2.5 py-1 text-sm text-ink-soft transition-colors hover:text-ink">
                    <input type="radio" name="rating" value={o.v} checked={o.v === '0'} class="size-4 accent-[#0e4fc0]" data-rating />
                    {o.l}
                  </label>
                ))}
              </div>
            </div>
          </aside>

          <!-- Résultats -->
          <div>
            <div class="mb-5 flex items-center justify-between gap-4">
              <p class="text-sm text-ink-soft">
                <span class="font-bold text-ink" data-count>{list.length}</span> établissement<span data-plural>{list.length > 1 ? 's' : ''}</span>
              </p>
              <div class="flex items-center gap-2">
                <span class="hidden text-sm text-ink-faint sm:inline">Trier&nbsp;:</span>
                <SortSelect
                  options={[
                    { value: 'default', label: 'Pertinence' },
                    { value: 'rating', label: 'Mieux notés' },
                    { value: 'reviews', label: 'Plus d’avis' },
                    { value: 'az', label: 'A → Z' },
                  ]}
                />
              </div>
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-grid>
              {list.map((b) => <BusinessCard business={b} compact />)}
            </div>

            <div class="hidden rounded-[12px] border border-dashed border-border bg-surface p-12 text-center" data-empty>
              <Icon name="ph:magnifying-glass-bold" class="mx-auto size-8 text-ink-faint" />
              <p class="mt-3 font-semibold text-ink">Aucun résultat</p>
              <p class="mt-1 text-sm text-ink-soft">Essayez d’élargir vos filtres.</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<script>
  const panel = document.querySelector<HTMLElement>('[data-filters]');
  const bar = document.querySelector<HTMLElement>('[data-search-bar]');
  if (panel && bar) {
    const grid = document.querySelector<HTMLElement>('[data-grid]')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-card]'));
    const qInput = bar.querySelector<HTMLInputElement>('[data-q]')!;
    const communeInput = bar.querySelector<HTMLInputElement>('[data-commune-input]')!;
    const openBox = panel.querySelector<HTMLInputElement>('[data-open]')!;
    const ratingRadios = Array.from(panel.querySelectorAll<HTMLInputElement>('[data-rating]'));
    const sortSel = document.querySelector<HTMLSelectElement>('[data-sort]')!;
    const resetBtn = panel.querySelector<HTMLButtonElement>('[data-reset]')!;
    const countEl = document.querySelector<HTMLElement>('[data-count]');
    const pluralEl = document.querySelector<HTMLElement>('[data-plural]');

    const slugToName: Record<string, string> = {};
    bar.querySelectorAll<HTMLElement>('.commune-option').forEach((o) => {
      slugToName[o.dataset.value ?? ''] = o.dataset.name ?? '';
    });

    let commune = '';
    const norm = (s: string) => s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();

    function apply() {
      const q = norm(qInput.value.trim());
      const minR = Number(ratingRadios.find((r) => r.checked)?.value || '0');
      const openOnly = openBox.checked;

      let visible = 0;
      cards.forEach((card) => {
        const okQ = !q || (card.dataset.search || '').includes(q);
        const okCom = !commune || card.dataset.commune === commune;
        const okR = Number(card.dataset.rating) >= minR;
        const okOpen = !openOnly || card.dataset.open === '1';
        const show = okQ && okCom && okR && okOpen;
        card.hidden = !show;
        if (show) visible++;
      });

      const key = sortSel.value;
      cards
        .filter((c) => !c.hidden)
        .sort((a, b) => {
          if (key === 'rating') return Number(b.dataset.rating) - Number(a.dataset.rating);
          if (key === 'reviews') return Number(b.dataset.reviews) - Number(a.dataset.reviews);
          if (key === 'az') return (a.dataset.search || '').localeCompare(b.dataset.search || '');
          return cards.indexOf(a) - cards.indexOf(b);
        })
        .forEach((c) => grid.appendChild(c));

      if (countEl) countEl.textContent = String(visible);
      if (pluralEl) pluralEl.textContent = visible > 1 ? 's' : '';
      document.querySelector('[data-empty]')?.classList.toggle('hidden', visible > 0);
      grid.classList.toggle('hidden', visible === 0);
    }

    qInput.addEventListener('input', apply);
    communeInput.addEventListener('change', () => {
      commune = communeInput.value ? slugToName[communeInput.value] || '' : '';
      apply();
    });
    [openBox, sortSel, ...ratingRadios].forEach((el) => el.addEventListener('change', apply));
    bar.addEventListener('submit', (e) => { e.preventDefault(); apply(); });

    resetBtn.addEventListener('click', () => {
      qInput.value = '';
      openBox.checked = false;
      ratingRadios.forEach((r) => (r.checked = r.value === '0'));
      document.querySelector<HTMLElement>('[data-select-option][data-value="default"]')?.click();
      bar.querySelector<HTMLElement>('.commune-option[data-value=""]')?.click();
      apply();
    });

    const toggle = document.querySelector<HTMLButtonElement>('[data-filters-toggle]');
    const aside = document.querySelector<HTMLElement>('[data-filters-panel]');
    toggle?.addEventListener('click', () => {
      const open = aside?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });

    const params = new URLSearchParams(location.search);
    const q0 = params.get('q');
    if (q0) qInput.value = q0;
    const communeSlug = params.get('commune');
    if (communeSlug) {
      const opt = bar.querySelector<HTMLElement>(`.commune-option[data-value="${communeSlug}"]`);
      setTimeout(() => opt?.click(), 0);
    }
    apply();
  }
</script>
