---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BusinessCard from '../../components/BusinessCard.astro';
import { Icon } from 'astro-icon/components';
import { categories } from '../../data/categories';
import { businesses } from '../../data/businesses';

export function getStaticPaths() {
  return categories.map((c) => ({
    params: { categorie: c.slug },
    props: { category: c, list: businesses.filter((b) => b.categorySlug === c.slug) },
  }));
}

const { category, list } = Astro.props;
const base = import.meta.env.BASE_URL;
const communesInList = [...new Set(list.map((b) => b.commune))].sort();
---

<Base title={`${category.name} à Charleroi Métropole · charleroi.info`} description={`Trouvez les meilleurs établissements de la catégorie ${category.name} à Charleroi et dans toutes les communes.`}>
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <!-- Breadcrumb -->
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <a href={`${base}annuaire`} class="transition-colors hover:text-accent">Annuaire</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="text-ink">{category.name}</span>
      </div>
    </nav>

    <!-- Title -->
    <div class="border-b border-border bg-surface">
      <div class="u-container py-10">
        <div class="flex items-center gap-3">
          <span class="grid size-12 place-items-center rounded-[10px] bg-accent-tint text-accent">
            <Icon name={`ph:${category.icon}`} class="size-7" />
          </span>
          <div>
            <span class="section-mark"></span>
            <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">{category.name}</h1>
          </div>
        </div>
        <p class="mt-3 text-ink-soft">
          <span data-count>{list.length}</span> établissement{list.length > 1 ? 's' : ''} à Charleroi Métropole.
        </p>
      </div>
    </div>

    <div class="u-container pt-8">
      {list.length === 0 ? (
        <div class="rounded-[12px] border border-dashed border-border bg-surface p-12 text-center">
          <Icon name="ph:storefront-bold" class="mx-auto size-9 text-ink-faint" />
          <p class="mt-4 text-lg font-bold text-ink">Aucun établissement pour le moment</p>
          <p class="mt-1 text-ink-soft">Cette catégorie n’a pas encore de fiche. Vous gérez un tel établissement ?</p>
          <a href={`${base}ajouter`} class="btn btn-primary mt-5">
            <Icon name="ph:plus-bold" class="size-4" />
            Ajouter mon entreprise
          </a>
        </div>
      ) : (
        <>
          <!-- Filtres -->
          <div class="rounded-[12px] border border-border bg-surface p-4" data-filters>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <div class="flex flex-1 items-center gap-2.5 rounded-[8px] border border-border-strong px-3 py-2.5">
                <Icon name="ph:magnifying-glass-bold" class="size-4 shrink-0 text-ink-faint" />
                <input type="search" placeholder="Filtrer par nom…" class="w-full bg-transparent text-sm text-ink outline-none placeholder:text-ink-faint" data-q />
              </div>
              <div class="flex items-center gap-2.5">
                <button type="button" class="inline-flex items-center gap-1.5 rounded-[8px] border border-border-strong px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors aria-pressed:border-accent aria-pressed:bg-accent-tint aria-pressed:text-accent" aria-pressed="false" data-open-toggle>
                  <span class="size-1.5 rounded-full bg-[#16a34a]"></span>
                  Ouvert maintenant
                </button>
                <label class="sr-only" for="sort">Trier</label>
                <select id="sort" class="cursor-pointer rounded-[8px] border border-border-strong bg-surface px-3 py-2.5 text-sm font-medium text-ink outline-none" data-sort>
                  <option value="default">Pertinence</option>
                  <option value="rating">Mieux notés</option>
                  <option value="reviews">Plus d’avis</option>
                  <option value="az">A → Z</option>
                </select>
              </div>
            </div>

            {communesInList.length > 1 && (
              <div class="mt-3 flex flex-wrap gap-2 border-t border-border pt-3">
                <button type="button" class="chip aria-pressed:border-accent-tint-2 aria-pressed:bg-accent-tint aria-pressed:text-accent" aria-pressed="true" data-commune="">Toutes les communes</button>
                {communesInList.map((c) => (
                  <button type="button" class="chip aria-pressed:border-accent-tint-2 aria-pressed:bg-accent-tint aria-pressed:text-accent" aria-pressed="false" data-commune={c}>{c}</button>
                ))}
              </div>
            )}
          </div>

          <!-- Résultats -->
          <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-grid>
            {list.map((b) => <BusinessCard business={b} />)}
          </div>

          <div class="hidden rounded-[12px] border border-dashed border-border bg-surface p-12 text-center" data-empty>
            <Icon name="ph:magnifying-glass-bold" class="mx-auto size-8 text-ink-faint" />
            <p class="mt-3 font-semibold text-ink">Aucun résultat</p>
            <p class="mt-1 text-sm text-ink-soft">Essayez d’élargir vos filtres.</p>
          </div>
        </>
      )}
    </div>
  </main>

  <Footer />
</Base>

<script>
  const root = document.querySelector<HTMLElement>('[data-filters]');
  if (root) {
    const grid = document.querySelector<HTMLElement>('[data-grid]')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-card]'));
    const qInput = root.querySelector<HTMLInputElement>('[data-q]')!;
    const openToggle = root.querySelector<HTMLButtonElement>('[data-open-toggle]')!;
    const sortSel = root.querySelector<HTMLSelectElement>('[data-sort]')!;
    const communeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-commune]'));
    const countEl = document.querySelector<HTMLElement>('[data-count]');
    const emptyEl = document.querySelector<HTMLElement>('[data-empty]');

    let commune = '';
    let openOnly = false;

    const norm = (s: string) => s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();

    function apply() {
      const q = norm(qInput.value.trim());
      let visible = 0;
      cards.forEach((card) => {
        const okQ = !q || norm(card.dataset.name || '').includes(q);
        const okC = !commune || card.dataset.commune === commune;
        const okO = !openOnly || card.dataset.open === '1';
        const show = okQ && okC && okO;
        card.hidden = !show;
        if (show) visible++;
      });

      // Tri
      const key = sortSel.value;
      const shown = cards.filter((c) => !c.hidden);
      shown.sort((a, b) => {
        if (key === 'rating') return Number(b.dataset.rating) - Number(a.dataset.rating);
        if (key === 'reviews') return Number(b.dataset.reviews) - Number(a.dataset.reviews);
        if (key === 'az') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        return cards.indexOf(a) - cards.indexOf(b);
      });
      shown.forEach((c) => grid.appendChild(c));

      if (countEl) countEl.textContent = String(visible);
      emptyEl?.classList.toggle('hidden', visible > 0);
      grid.classList.toggle('hidden', visible === 0);
    }

    qInput.addEventListener('input', apply);
    sortSel.addEventListener('change', apply);
    openToggle.addEventListener('click', () => {
      openOnly = !openOnly;
      openToggle.setAttribute('aria-pressed', String(openOnly));
      apply();
    });
    communeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        commune = btn.dataset.commune || '';
        communeBtns.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        apply();
      });
    });
  }
</script>
