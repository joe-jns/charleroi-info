---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BusinessCard from '../components/BusinessCard.astro';
import JobCard from '../components/JobCard.astro';
import EventCard from '../components/EventCard.astro';
import BusinessMap from '../components/BusinessMap.astro';
import { Icon } from 'astro-icon/components';
import { communes } from '../data/communes';
import { businesses } from '../data/businesses';
import { latestJobs } from '../data/jobs';
import { upcomingEvents } from '../data/events';

export function getStaticPaths() {
  return communes.map((c) => ({ params: { commune: c.slug }, props: { commune: c } }));
}

const { commune } = Astro.props;
const base = import.meta.env.BASE_URL;

const bizList = businesses.filter((b) => b.commune === commune.name);
const jobList = latestJobs.filter((j) => j.commune === commune.name);
const eventList = upcomingEvents.filter((e) => e.commune === commune.name);
const topBiz = bizList.slice(0, 6);
---

<Base title={`${commune.name} (${commune.postal}) — commerces, emploi, événements · charleroi.info`} description={`Tout ${commune.name} : commerces, services, offres d’emploi et événements de la commune sur charleroi.info.`}>
  <Header />

  <main id="contenu" class="bg-surface-muted pb-20">
    <nav aria-label="Fil d’Ariane" class="border-b border-border bg-surface">
      <div class="u-container flex items-center gap-1.5 py-3 text-sm text-ink-faint">
        <a href={base} class="transition-colors hover:text-accent">Accueil</a>
        <Icon name="ph:caret-right-bold" class="size-3" />
        <span class="text-ink">{commune.name}</span>
      </div>
    </nav>

    <!-- En-tête commune -->
    <div class="border-b border-border bg-surface">
      <div class="u-container grid items-center gap-8 py-10 lg:grid-cols-[1fr_340px] lg:py-12">
        <div>
          <span class="section-mark"></span>
          <div class="flex flex-wrap items-baseline gap-3">
            <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">{commune.name}</h1>
            <span class="font-mono text-sm text-ink-faint">{commune.postal}</span>
          </div>
          <p class="mt-3 max-w-[52ch] text-ink-soft">
            Commerces, services, emploi et vie locale à {commune.name}, dans la métropole carolo.
          </p>

          <div class="mt-6 flex flex-wrap gap-6">
            <div>
              <p class="text-2xl font-extrabold text-ink">{bizList.length}</p>
              <p class="text-sm text-ink-faint">établissement{bizList.length > 1 ? 's' : ''}</p>
            </div>
            <div class="border-l border-border pl-6">
              <p class="text-2xl font-extrabold text-ink">{jobList.length}</p>
              <p class="text-sm text-ink-faint">offre{jobList.length > 1 ? 's' : ''} d’emploi</p>
            </div>
            <div class="border-l border-border pl-6">
              <p class="text-2xl font-extrabold text-ink">{eventList.length}</p>
              <p class="text-sm text-ink-faint">événement{eventList.length > 1 ? 's' : ''}</p>
            </div>
          </div>

          <a href={`${base}recherche?commune=${commune.slug}`} class="btn btn-primary mt-6">
            <Icon name="ph:magnifying-glass-bold" class="size-4" />
            Explorer {commune.name}
          </a>
        </div>

        <div class="rounded-[12px] border border-border bg-surface p-2">
          <BusinessMap lat={commune.lat} lng={commune.lng} name={commune.name} />
        </div>
      </div>
    </div>

    <!-- Établissements -->
    <section class="u-container pt-12">
      <div class="flex items-end justify-between gap-6">
        <div>
          <span class="section-mark"></span>
          <h2 class="text-2xl font-extrabold tracking-tight">Établissements à {commune.name}</h2>
        </div>
        {bizList.length > 0 && (
          <a href={`${base}recherche?commune=${commune.slug}`} class="hidden shrink-0 items-center gap-1.5 text-[0.9rem] font-semibold text-accent transition-colors hover:text-accent-hover sm:inline-flex">
            Tout voir
            <Icon name="ph:arrow-right-bold" class="size-4" />
          </a>
        )}
      </div>

      {topBiz.length > 0 ? (
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {topBiz.map((b) => <BusinessCard business={b} compact />)}
        </div>
      ) : (
        <div class="mt-6 rounded-[12px] border border-dashed border-border bg-surface p-10 text-center">
          <Icon name="ph:storefront-bold" class="mx-auto size-8 text-ink-faint" />
          <p class="mt-3 font-semibold text-ink">Aucun établissement listé à {commune.name}</p>
          <p class="mt-1 text-sm text-ink-soft">Vous en gérez un ? Ajoutez-le gratuitement.</p>
          <a href={`${base}ajouter`} class="btn btn-primary mt-5">
            <Icon name="ph:plus-bold" class="size-4" />
            Ajouter mon entreprise
          </a>
        </div>
      )}
    </section>

    <!-- Emploi + Événements -->
    {(jobList.length > 0 || eventList.length > 0) && (
      <section class="u-container pt-14">
        <div class="grid gap-8 lg:grid-cols-2">
          {jobList.length > 0 && (
            <div>
              <div class="flex items-end justify-between gap-4">
                <h2 class="text-xl font-extrabold tracking-tight">Offres d’emploi</h2>
                <a href={`${base}emploi?commune=${commune.slug}`} class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover">
                  Tout voir <Icon name="ph:arrow-right-bold" class="size-3.5" />
                </a>
              </div>
              <div class="mt-4 space-y-3">
                {jobList.slice(0, 4).map((j) => <JobCard job={j} />)}
              </div>
            </div>
          )}

          {eventList.length > 0 && (
            <div>
              <div class="flex items-end justify-between gap-4">
                <h2 class="text-xl font-extrabold tracking-tight">Événements</h2>
                <a href={`${base}evenements?commune=${commune.slug}`} class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-accent-hover">
                  Tout voir <Icon name="ph:arrow-right-bold" class="size-3.5" />
                </a>
              </div>
              <div class="mt-4 space-y-3">
                {eventList.slice(0, 4).map((e) => <EventCard event={e} />)}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- CTA pro -->
    <section class="u-container pt-14">
      <div class="flex flex-col items-start justify-between gap-5 rounded-[14px] border border-border bg-surface p-6 sm:flex-row sm:items-center sm:p-8">
        <div>
          <h2 class="text-xl font-extrabold tracking-tight">Vous gérez un commerce à {commune.name} ?</h2>
          <p class="mt-1.5 text-ink-soft">Référencez-le gratuitement et touchez toute la métropole.</p>
        </div>
        <a href={`${base}ajouter`} class="btn btn-primary shrink-0">
          <Icon name="ph:plus-bold" class="size-4" />
          Ajouter mon entreprise
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
