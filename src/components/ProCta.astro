---
import { Icon } from 'astro-icon/components';
---

<section class="bg-accent">
  <div class="u-container flex flex-col gap-6 py-14 md:flex-row md:items-center md:justify-between lg:py-16">
    <div>
      <div class="flex items-center gap-2 text-white/80">
        <Icon name="ph:storefront-bold" class="size-5" />
        <span class="text-sm font-semibold">Espace professionnel</span>
      </div>
      <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-white sm:text-3xl">
        Vous gérez un commerce à Charleroi ?
      </h2>
      <p class="mt-2 max-w-[52ch] text-white/85">
        Référencez votre établissement gratuitement et soyez visible auprès de
        toute la métropole.
      </p>
    </div>

    <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
      <a
        href={`${import.meta.env.BASE_URL}ajouter`}
        class="inline-flex items-center justify-center gap-2 rounded-[8px] bg-white px-5 py-3 text-[0.95rem] font-semibold text-accent transition-colors hover:bg-white/90 active:translate-y-px"
      >
        <Icon name="ph:plus-bold" class="size-4" />
        Ajouter mon entreprise
      </a>
      <a
        href={`${import.meta.env.BASE_URL}pro`}
        class="inline-flex items-center justify-center gap-2 rounded-[8px] border border-white/40 px-5 py-3 text-[0.95rem] font-semibold text-white transition-colors hover:bg-white/10 active:translate-y-px"
      >
        Comment ça marche
      </a>
    </div>
  </div>
</section>
