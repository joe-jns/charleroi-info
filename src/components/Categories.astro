---
import { Icon } from 'astro-icon/components';
import { categories } from '../data/categories';
---

<section class="border-b border-border bg-surface">
  <div class="u-container py-16 lg:py-20">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="section-mark"></span>
        <h2 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
          Parcourir par catégorie
        </h2>
        <p class="mt-2 max-w-[52ch] text-ink-soft">
          Explorez les commerces et services de la métropole, secteur par secteur.
        </p>
      </div>

      <a
        href={`${import.meta.env.BASE_URL}annuaire`}
        class="hidden shrink-0 items-center gap-1.5 text-[0.9rem] font-semibold text-accent transition-colors hover:text-accent-hover sm:inline-flex"
      >
        Tout l’annuaire
        <Icon name="ph:arrow-right-bold" class="size-4" />
      </a>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4">
      {categories.map((c) => (
        <a
          href={`${import.meta.env.BASE_URL}annuaire/${c.slug}`}
          class="group flex items-center gap-3 rounded-[10px] border border-border bg-surface px-3.5 py-4 transition-colors hover:border-accent-tint-2 hover:bg-accent-tint sm:gap-3.5 sm:px-4"
        >
          <span class="grid size-10 shrink-0 place-items-center rounded-[8px] bg-accent-tint text-accent transition-colors group-hover:bg-accent group-hover:text-accent-ink sm:size-11">
            <Icon name={`ph:${c.icon}`} class="size-[1.35rem] sm:size-6" />
          </span>
          <span class="min-w-0 flex-1 text-[0.9rem] font-semibold leading-tight text-ink sm:text-base">
            {c.name}
          </span>
          <Icon
            name="ph:caret-right-bold"
            class="hidden size-4 shrink-0 text-ink-faint transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-accent sm:block"
          />
        </a>
      ))}
    </div>

    <a
      href={`${import.meta.env.BASE_URL}annuaire`}
      class="mt-6 inline-flex items-center gap-1.5 text-[0.9rem] font-semibold text-accent transition-colors hover:text-accent-hover sm:hidden"
    >
      Tout l’annuaire
      <Icon name="ph:arrow-right-bold" class="size-4" />
    </a>
  </div>
</section>
