---
import { Icon } from 'astro-icon/components';
import type { Article } from '../data/articles';

interface Props {
  article: Article;
  featured?: boolean;
}
const { article: a, featured = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}actualites/${a.slug}`}
  class:list={[
    'group overflow-hidden rounded-[12px] border border-border bg-surface transition-all duration-200 hover:-translate-y-0.5 hover:border-border-strong hover:shadow-[0_12px_30px_rgba(15,23,41,0.08)]',
    featured ? 'grid md:grid-cols-2' : 'flex flex-col',
  ]}
  data-card
  data-category={a.category}
>
  <div class:list={['relative overflow-hidden bg-surface-muted', featured ? 'aspect-[16/10] md:aspect-auto' : 'aspect-[16/9]']}>
    {/* TODO: vraie photo de l'article */}
    <img src={`https://picsum.photos/seed/${a.imageSeed}/800/500`} alt={a.title} loading={featured ? 'eager' : 'lazy'} class="size-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
    <span class="absolute left-3 top-3 rounded-full bg-surface/95 px-2.5 py-1 text-xs font-semibold text-accent shadow-sm backdrop-blur-sm">{a.category}</span>
  </div>

  <div class:list={['flex flex-1 flex-col', featured ? 'p-6 md:justify-center' : 'p-4']}>
    <h3 class:list={['font-extrabold tracking-tight text-ink transition-colors group-hover:text-accent', featured ? 'text-xl sm:text-2xl' : 'text-[1.05rem] leading-snug']}>
      {a.title}
    </h3>
    <p class:list={['text-ink-soft', featured ? 'mt-3 leading-relaxed' : 'mt-2 line-clamp-2 text-sm leading-relaxed']}>
      {a.excerpt}
    </p>
    <div class="mt-auto flex items-center gap-2 pt-4 text-xs text-ink-faint">
      <span>{a.author}</span>
      <span>·</span>
      <span>{a.date}</span>
      <span>·</span>
      <span class="inline-flex items-center gap-1"><Icon name="ph:clock-bold" class="size-3.5" />{a.readingTime}</span>
    </div>
  </div>
</a>
