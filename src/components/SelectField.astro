---
import { Icon } from 'astro-icon/components';

interface Option {
  value: string;
  label: string;
}
interface Props {
  name: string;
  options: Option[];
  placeholder?: string;
}
const { name, options, placeholder = 'Sélectionner…' } = Astro.props;
---

<div class="relative" data-fselect>
  <input type="hidden" name={name} value="" data-fselect-input />

  <button
    type="button"
    class="flex w-full items-center justify-between gap-2 rounded-[8px] border border-border-strong bg-surface px-3.5 py-2.5 text-left text-[0.95rem] text-ink-faint transition-colors hover:border-ink-faint aria-expanded:border-accent"
    data-fselect-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <span data-fselect-label>{placeholder}</span>
    <Icon name="ph:caret-down-bold" class="size-3.5 shrink-0 text-ink-faint transition-transform duration-200" data-fselect-caret />
  </button>

  <div
    class="scrollbar-civic absolute left-0 top-[calc(100%+0.4rem)] z-50 hidden max-h-64 w-full overflow-auto rounded-[10px] border border-border bg-surface p-1 shadow-[0_18px_50px_rgba(9,13,22,0.22)]"
    role="listbox"
    data-fselect-menu
  >
    {options.map((o) => (
      <button
        type="button"
        role="option"
        class="group flex w-full items-center gap-2 rounded-[6px] px-3 py-2 text-left text-sm text-ink transition-colors hover:bg-surface-muted aria-selected:bg-accent-tint aria-selected:text-accent"
        data-fselect-option
        data-value={o.value}
        aria-selected="false"
      >
        <Icon name="ph:check-bold" class="size-4 shrink-0 text-accent opacity-0 group-aria-selected:opacity-100" />
        <span class="flex-1">{o.label}</span>
      </button>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-fselect]').forEach((root) => {
    const input = root.querySelector<HTMLInputElement>('[data-fselect-input]')!;
    const trigger = root.querySelector<HTMLButtonElement>('[data-fselect-trigger]')!;
    const label = root.querySelector<HTMLElement>('[data-fselect-label]')!;
    const caret = root.querySelector<HTMLElement>('[data-fselect-caret]')!;
    const menu = root.querySelector<HTMLElement>('[data-fselect-menu]')!;
    const options = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-fselect-option]'));

    const open = () => {
      menu.classList.remove('hidden');
      trigger.setAttribute('aria-expanded', 'true');
      caret.style.transform = 'rotate(180deg)';
    };
    const close = () => {
      menu.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
      caret.style.transform = '';
    };

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.contains('hidden') ? open() : close();
    });

    options.forEach((opt) => {
      opt.addEventListener('click', () => {
        options.forEach((o) => o.setAttribute('aria-selected', String(o === opt)));
        label.textContent = opt.textContent!.trim();
        label.classList.remove('text-ink-faint');
        label.classList.add('text-ink');
        input.value = opt.dataset.value ?? '';
        input.dispatchEvent(new Event('change', { bubbles: true }));
        close();
      });
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  });
</script>
