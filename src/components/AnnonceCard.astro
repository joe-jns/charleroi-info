---
import { Icon } from 'astro-icon/components';
import type { Annonce } from '../data/annonces';

interface Props {
  annonce: Annonce;
}
const { annonce: a } = Astro.props;
const base = import.meta.env.BASE_URL;
const norm = (s: string) => s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();
const search = norm(`${a.title} ${a.category} ${a.commune}`);
---

<a
  href={`${base}annonces/${a.slug}`}
  class="group flex flex-col overflow-hidden rounded-[12px] border border-border bg-surface transition-all duration-200 hover:-translate-y-0.5 hover:border-border-strong hover:shadow-[0_12px_30px_rgba(15,23,41,0.08)]"
  data-card
  data-search={search}
  data-category={a.category}
  data-commune={a.commune}
>
  <div class="relative aspect-[4/3] overflow-hidden bg-surface-muted">
    {/* TODO: vraie photo de l'annonce */}
    <img src={`https://picsum.photos/seed/${a.imageSeed}/600/450`} alt={a.title} loading="lazy" class="size-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
    {a.condition && (
      <span class="absolute left-3 top-3 rounded-full bg-surface/95 px-2.5 py-1 text-xs font-semibold text-ink-soft shadow-sm backdrop-blur-sm">{a.condition}</span>
    )}
  </div>
  <div class="flex flex-1 flex-col p-4">
    <p class="text-lg font-extrabold text-ink">{a.price}</p>
    <h3 class="mt-0.5 line-clamp-1 font-semibold text-ink transition-colors group-hover:text-accent">{a.title}</h3>
    <div class="mt-auto flex items-center gap-1.5 pt-3 text-xs text-ink-faint">
      <Icon name="ph:map-pin-bold" class="size-3.5" />
      {a.commune}
      <span class="mx-1">·</span>
      {a.posted}
    </div>
  </div>
</a>
